# Copy this file to .env and fill in the values before starting the stack.
# Never commit .env to version control.

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://prisma:prisma@db:5432/prisma

# Anthropic Claude API key for Narrative Engine and Multi-Agent Deep-Dive
ANTHROPIC_API_KEY=sk-ant-...

# Application environment: "development" | "staging" | "production"
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# Internal API key consumed by the MCP server (Layer 3)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-before-production

# FinancialModelingPrep API key (free tier, 250 calls/day)
# Used by Quality Classic for Schweizer Tickers, wo Yahoo Fundamentals luekenhaft sind.
# Siehe ADR 0005 und docs/specs/2026-04-27-quant-models-redesign.md.
FMP_API_KEY=your-fmp-key

# Finnhub API key (free tier) — fuer Layer-2 Sentiment-Agent (post-MVP)
FINNHUB_API_KEY=your-finnhub-key

# Monatliches AI-Budget-Cap in USD (App-seitige Sicherung; setzt vor dem
# Anthropic-Console-Spend-Limit ein). Default 20.00 für Production; Demo-Setup
# wird tiefer setzen, z.B. 8.00.
BUDGET_CAP_USD=20.00

# Anteil des Caps, bei dem `check_cap` abbricht (Range 0.0–1.0).
BUDGET_CAP_THRESHOLD=0.95

# VoyageAI Embedding-Key — für semantische Suche (pgvector RAG)
# https://www.voyageai.com/
VOYAGE_API_KEY=your-voyage-api-key

# MCP-Tool-API-Key für X-API-Key-Header auf /api/v1/runs (getrennt vom Admin-Key api_key).
# Leer lassen um Auth auf diesem Endpunkt zu deaktivieren.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOOL_API_KEY=

# SendGrid API key for e-mail notifications from the Alert Engine
SENDGRID_API_KEY=your-sendgrid-api-key

# Public URL of the backend — consumed by the Next.js frontend at build time.
# Local development: http://localhost:8000
# Production (Render): https://prisma-v2-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
